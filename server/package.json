    "lint": "bunx --bun @biomejs/biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "latest",
    "drizzle-kit": "^1.0.0-beta.22"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@elysia/cors": "^1.4.2",
    "@elysia/openapi": "^1.4.15",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^1.0.0-beta.22",
    "elysia": "^1.4.28",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  }
