{
  "name": "server",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "fix": "bunx --bun @biomejs/biome check --write",
    "auth:generate": "bun x auth@latest generate --config ./src/lib/auth.ts --output ./src/drizzle/models/auth-schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/openapi": "^1.4.15",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^1.0.0-beta.22",
    "elysia": "latest",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "bun-types": "latest",
    "drizzle-kit": "^1.0.0-beta.22"
  },
  "module": "src/index.js"
}
